{
  "name": "@farisulhaq/universal-picker",
  "version": "3.1.0",
  "description": "A lightweight, zero-dependency date range picker. Supports calendar, accounting period, and double-date modes.",
  "main": "dist/universal-picker.js",
  "module": "dist/universal-picker.esm.js",
  "browser": "dist/universal-picker.min.js",
  "unpkg": "dist/universal-picker.min.js",
  "jsdelivr": "dist/universal-picker.min.js",
  "types": "types/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/universal-picker.esm.js",
      "require": "./dist/universal-picker.js",
      "types": "./types/index.d.ts",
      "default": "./dist/universal-picker.js"
    }
  },
  "sideEffects": false,
  "files": [
    "dist/",
    "types/",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "rollup -c rollup.config.mjs",
    "prepublishOnly": "npm run build"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/farisulhaq/universal-picker.git"
  },
  "keywords": [
    "datepicker",
    "daterangepicker",
    "date-range-picker",
    "calendar",
    "date-picker",
    "accounting",
    "doubledate",
    "picker",
    "vanilla-js",
    "no-dependency",
    "lightweight",
    "typescript"
  ],
  "author": "farisulhaq",
  "license": "MIT",
  "bugs": {
    "url": "https://github.com/farisulhaq/universal-picker/issues"
  },
  "homepage": "https://github.com/farisulhaq/universal-picker#readme",
  "devDependencies": {
    "@rollup/plugin-replace": "^6.0.3",
    "@rollup/plugin-terser": "^1.0.0",
    "rollup": "^4.60.1"
  }
}
